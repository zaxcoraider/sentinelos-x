# Casper node RPC endpoints
CASPER_NODE_URL=https://rpc.testnet.casperlabs.io
CASPER_CHAIN_NAME=casper-test

# CSPR.cloud API (sign up at https://cspr.cloud)
CSPR_CLOUD_API_KEY=your_api_key_here

# Your account hash (output of: casper-client account-address --public-key ./keys/public_key_hex)
CASPER_ACCOUNT_HASH=account-hash-xxxx

# Claude — powers the SentinelOS agent loop (packages/agents). Get a key at
# https://console.anthropic.com/ -> API Keys.
ANTHROPIC_API_KEY=sk-ant-xxxx
# Optional agent tuning:
# AGENT_MODEL=claude-opus-4-8        # default
# AGENT_THINKING=adaptive            # or "off" for a snappier demo
# AGENT_EFFORT=medium                # low | medium | high | max
# AGENT_ROUTE_THRESHOLD=60           # Commander acts when severity exceeds this

# x402 premium-data leg (services/premium-data + agents):
# X402_MODE=stub                     # "stub" (no chain) or "live" (real CSPR transfer)
# X402_ENABLED=true                  # set false to skip the premium-data fetch
# PREMIUM_DATA_URL=http://localhost:4021/volatility
# X402_PORT=4021                     # premium-data server port
# X402_PRICE_MOTES=2500000000        # 2.5 CSPR (Casper native-transfer minimum)
# X402_PAY_TO=                       # merchant pubkey hex (defaults to CASPER_PUBLIC_KEY_HEX)
# CASPER_PUBLIC_KEY_HEX=             # used as the default x402 payee (self-settlement demo)
